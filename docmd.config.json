{
  "title": "Документация Mercury Bot",
  "url": "https://mercurybot.space",
  "base": "/space/",
  "src": "docs",
  "out": "site",
  "engine": "js",
  "layout": {
    "spa": true,
    "header": {
      "enabled": true
    },
    "sidebar": {
      "collapsible": true,
      "defaultCollapsed": false
    },
    "optionsMenu": {
      "position": "sidebar-top",
      "components": {
        "search": true,
        "themeSwitch": true
      }
    },
    "footer": {
      "style": "minimal",
      "content": "© 2026 Mercury Bot.",
      "branding": true
    }
  },
  "theme": {
    "name": "default",
    "appearance": "system",
    "codeHighlight": true
  },
  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "navigation": [
    { "title": "Главная", "path": "/", "icon": "home" },
    {
      "title": "Функционал бота",
      "icon": "rocket",
      "collapsible": false,
      "children": [
        { "title": "Подписки", "path": "/subscriptions", "icon": "star" },
        { "title": "Экономика", "path": "/economy", "icon": "coin" },
        { "title": "Премиум Эмодзи", "path": "/premium-emojis", "icon": "smile" },
        { "title": "Модерация", "path": "/moderation", "icon": "shield" }
      ]
    },
    { "title": "GitHub", "path": "https://github.com/docmd-io/docmd", "icon": "github", "external": true }
  ],
  "plugins": {
    "git": {
      "commitHistory": true,
      "maxCommits": 5
    },
    "seo": {
      "defaultDescription": "Официальная документация по настройке и использованию Mercury Bot."
    }
  }
}